DATABASE_URL="file:./dev.db"

# Optional: enables server-side model vision date recognition before local OCR fallback.
# Provider order: Gemini -> OpenRouter -> OpenAI -> local OCR.
OPENROUTER_API_KEY=""
OPENROUTER_DATE_MODEL="google/gemma-4-31b-it:free"
OPENROUTER_PROXY_URL=""

GEMINI_API_KEY=""
GEMINI_DATE_MODEL="gemini-2.5-flash"
GEMINI_PROXY_URL=""

OPENAI_API_KEY=""
OPENAI_DATE_MODEL="gpt-4.1"
OPENAI_PROXY_URL=""

# Optional: enables local AI cartoon cover generation for cabinet/location photos.
# Use ComfyUI with an API-format workflow JSON. In the workflow JSON, use these placeholders:
# __INPUT_IMAGE__ for the uploaded reference image, __PROMPT__ for the positive prompt,
# __NEGATIVE_PROMPT__ for the negative prompt, and __SEED__ for a numeric seed.
COMFYUI_BASE_URL="http://127.0.0.1:8188"
COMFYUI_WORKFLOW_PATH=""
COMFYUI_PROXY_URL=""
