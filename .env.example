DATABASE_URL="file:./dev.db"

# Optional: enables server-side model vision date recognition before local OCR fallback.
# Provider order: OpenRouter -> Gemini -> OpenAI -> local OCR.
OPENROUTER_API_KEY=""
OPENROUTER_DATE_MODEL="google/gemma-4-31b-it:free"
OPENROUTER_PROXY_URL=""

GEMINI_API_KEY=""
GEMINI_DATE_MODEL="gemini-2.5-flash"
GEMINI_PROXY_URL=""

OPENAI_API_KEY=""
OPENAI_DATE_MODEL="gpt-4.1"
OPENAI_PROXY_URL=""
